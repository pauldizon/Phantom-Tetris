def handle_events() -> None:
    global done, pressing_down, player_name

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            done = True

        if event.type == pygame.KEYDOWN:
            if game.state == GameState.START:
                if event.key in (pygame.K_RETURN, pygame.K_SPACE):
                    game.state = GameState.PLAYING
                elif event.key == pygame.K_h:
                    game.state = GameState.HOW_TO_PLAY
                elif event.key == pygame.K_s:
                    game.state = GameState.SCOREBOARD

            elif game.state == GameState.HOW_TO_PLAY:
                if event.key in (pygame.K_ESCAPE, pygame.K_BACKSPACE):
                    game.state = GameState.START

            elif game.state == GameState.SCOREBOARD:
                if event.key in (pygame.K_ESCAPE, pygame.K_BACKSPACE):
                    game.reset()
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound
                    game.state = GameState.START

            elif game.state == GameState.ENTER_NAME:
                if event.key == pygame.K_RETURN and player_name.strip():
                    game.add_score(player_name.strip())
                    player_name = ""
                    game.state = GameState.SCOREBOARD
                elif event.key == pygame.K_BACKSPACE:
                    player_name = player_name[:-1]
                elif event.key == pygame.K_ESCAPE:
                    game.add_score("Player")
                    player_name = ""
                    game.state = GameState.SCOREBOARD
                elif (
                    len(player_name) < 15
                    and event.unicode.isprintable()
                    and event.unicode not in ['\r', '\n', '\t']
                ):
                    player_name += event.unicode

            elif game.state == GameState.PLAYING:
                if event.key == pygame.K_UP:
                    game.rotate()
                if event.key == pygame.K_DOWN:
                    pressing_down = True
                if event.key == pygame.K_LEFT:
                    game.go_side(-1)
                if event.key == pygame.K_RIGHT:
                    game.go_side(1)
                if event.key == pygame.K_SPACE:
                    game.go_space()
                if event.key == pygame.K_ESCAPE:
                    game.reset()
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound

            elif game.state == GameState.GAMEOVER:
                if event.key == pygame.K_ESCAPE:
                    game.reset()
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound
                    player_name = ""

        if event.type == pygame.KEYUP:
            if event.key == pygame.K_DOWN:
                pressing_down = False


def update_game() -> None:
    global counter

    if game.state == GameState.PLAYING and game.figure is None:
        game.new_figure()

    counter += 1
    if counter > 100000:
        counter = 0

    # Constant fall speed
    fall_speed = 5
    if game.state == GameState.PLAYING and (counter % fall_speed == 0 or pressing_down):
        game.go_down()


def render_game() -> None:
    screen.fill(BLACK)

    # --- START screen ---
    if game.state == GameState.START:
        screen.blit(title_font.render("Phantom Tetris", True, WHITE), [20, 140])
        screen.blit(font.render("Press ENTER or SPACE to start", True, WHITE), [40, 220])
        screen.blit(font.render("Arrow keys to move, ESC to reset", True, WHITE), [40, 260])
        screen.blit(font.render("Press H for How to Play", True, WHITE), [40, 290])
        screen.blit(font.render("Press S for Scoreboard", True, WHITE), [40, 320])
        screen.blit(font.render("By Team LEAP @BSCPE-1A 2025-2026", True, WHITE), [40, 350])
        pygame.display.flip()
        return

    # --- HOW TO PLAY screen ---
    if game.state == GameState.HOW_TO_PLAY:
        screen.blit(title_font.render("How to Play", True, WHITE), [120, 20])
        instructions = [
            ("OBJECTIVE:", True),
            ("Clear rows by filling them completely", False),
            ("Avoid blocks reaching the red line!", False),
            ("", False),
            ("CONTROLS:", True),
            ("LEFT/RIGHT ARROW - Move piece", False),
            ("UP ARROW - Rotate piece", False),
            ("DOWN ARROW - Move piece down faster", False),
            ("SPACE - Drop piece instantly", False),
            ("ESC - Reset game", False),
            ("", False),
            ("SPECIAL PIECES:", True),
            ("Yellow Bomb - clears a 3x3 area", False),
            ("Orange Heavy - no rotation, +5 pts", False),
            ("Teal Ice - freezes neighboring blocks", False),
            ("Row 15 (red line) disables outer columns", False),
            ("", False),
            ("Press ESC or BACKSPACE to go back", False),
        ]
        y_pos = 60
        for text, is_header in instructions:
            if text == "":
                y_pos += 8
                continue
            color = GOLD if is_header else WHITE
            screen.blit(font.render(text, True, color), [20, y_pos])
            y_pos += 22
        pygame.display.flip()
        return

    # --- SCOREBOARD screen ---
    if game.state == GameState.SCOREBOARD:
        screen.blit(title_font.render("High Scores", True, WHITE), [100, 30])
        scores = game.load_high_scores()
        y_pos = 100
        if scores:
            screen.blit(font.render("Rank   Name           Score", True, GOLD), [30, y_pos])
            y_pos += 35
            for rank, entry in enumerate(scores[:10], 1):
                line = f"{rank:2d}.   {entry['name']:<15} {entry['score']}"
                screen.blit(font.render(line, True, WHITE), [30, y_pos])
                y_pos += 28
        else:
            screen.blit(font.render("No scores yet. Play a game!", True, WHITE), [50, 150])
        screen.blit(font.render("Press ESC or BACKSPACE to go back", True, DIM), [20, 460])
        pygame.display.flip()
        return

    # --- ENTER NAME screen ---
    if game.state == GameState.ENTER_NAME:
        screen.blit(title_font.render("Enter Your Name", True, WHITE), [80, 30])
        screen.blit(font.render(f"Your Score: {game.score}", True, GOLD), [100, 100])
        screen.blit(font.render("Enter your name:", True, WHITE), [100, 150])
        name_display = (player_name + "_") if len(player_name) < 15 else player_name
        if not player_name:
            name_display = "Type your name..."
        screen.blit(font.render(name_display, True, GOLD), [100, 180])
        for i, line in enumerate([
            "Type your name (max 15 characters)",
            "Press ENTER to save score",
            "Press ESC to use 'Player'",
            "Press BACKSPACE to delete",
        ]):
            screen.blit(font.render(line, True, DIM), [50, 250 + i * 25])
        pygame.display.flip()
        return

    # --- PLAYING / GAMEOVER board ---
    for i in range(game.height):
        for j in range(game.width):
            # Skip disabled columns (don't draw grid or pieces there)
            if j in game.disabled_columns:
                continue
            grid_color = (255, 0, 0) if i == 14 else GRAY
            pygame.draw.rect(screen, grid_color,
                             [game.x + game.zoom * j, game.y + game.zoom * i, game.zoom, game.zoom], 1)
            if game.field[i][j] > 0:
                pygame.draw.rect(screen, colors[game.field[i][j]],
                                 [game.x + game.zoom * j + 1, game.y + game.zoom * i + 1,
                                  game.zoom - 2, game.zoom - 1])

    # Draw active figure
    if game.figure is not None:
        for i in range(4):
            for j in range(4):
                if i * 4 + j in game.figure.image():
                    col = j + game.figure.x
                    if col not in game.disabled_columns:
                        pygame.draw.rect(screen, colors[game.figure.color],
                                         [game.x + game.zoom * col + 1,
                                          game.y + game.zoom * (i + game.figure.y) + 1,
                                          game.zoom - 2, game.zoom - 2])

    # HUD
    screen.blit(font.render("Score: " + str(game.score), True, WHITE), [0, 0])

    if game.columns_hidden and game.state == GameState.PLAYING:
        msg = font.render("Outer columns disabled!", True, (255, 0, 0))
        screen.blit(msg, msg.get_rect(center=(size[0] // 2, game.y - 12)))

    # GAMEOVER overlay
    if game.state == GameState.GAMEOVER:
        screen.blit(font1.render("Game Over", True, (255, 125, 0)), [20, 150])
        screen.blit(font1.render("Press ESC", True, GOLD), [25, 215])
        screen.blit(font.render(f"Your Score: {game.score}", True, GOLD), [60, 290])
        screen.blit(font.render("Top Scores:", True, WHITE), [60, 320])
        scores = game.load_high_scores()
        for rank, entry in enumerate(scores[:3], 1):
            screen.blit(font.render(f"{rank}. {entry['name']}: {entry['score']}", True, WHITE),
                        [70, 320 + rank * 25])

    pygame.display.flip()


# =============================================================================
# MAIN LOOP
# =============================================================================
while not done:
    handle_events()
    update_game()
    render_game()
    clock.tick(fps)

pygame.quit()
