# =============================================================================
# ABSTRACT PIECE BASE CLASS
# =============================================================================
class AbstractPiece(ABC):
    def __init__(self, x, y):
        self.x = x
        self.y = y
        self.rotation = 0

    @abstractmethod
    def image(self):
        pass

    @abstractmethod
    def place(self, game):
        pass

    @abstractmethod
    def rotate(self):
        pass

# =============================================================================
# FIGURE (Standard Tetromino)
# =============================================================================
class Figure(AbstractPiece):
    figures = [
        [[1, 5, 9, 13], [4, 5, 6, 7]],
        [[4, 5, 9, 10], [2, 6, 5, 9]],
        [[6, 7, 9, 10], [1, 5, 6, 10]],
        [[1, 2, 5, 9], [0, 4, 5, 6], [1, 5, 9, 8], [4, 5, 6, 10]],
        [[1, 2, 6, 10], [5, 6, 7, 9], [2, 6, 10, 11], [3, 5, 6, 7]],
        [[1, 4, 5, 6], [1, 4, 5, 9], [4, 5, 6, 9], [1, 5, 6, 9]],
        [[1, 2, 5, 6]],
        [[5]],  # Bomb: single cube
    ]

    def __init__(self, x, y):
        super().__init__(x, y)
        self.type = random.randint(0, len(self.figures) - 2)  # Exclude bomb type
        self.color = random.randint(1, len(colors) - 2)
        self.is_bomb = False

    def image(self):
        return self.figures[self.type][self.rotation]

    def place(self, game: 'Tetris') -> None:
        for i in range(4):
            for j in range(4):
                if i * 4 + j in self.image():
                    game.field[i + self.y][j + self.x] = self.color

    def rotate(self) -> None:
        self.rotation = (self.rotation + 1) % len(self.figures[self.type])

# =============================================================================
# BOMB FIGURE
# =============================================================================
class BombFigure(Figure):
    def __init__(self, x, y):
        super().__init__(x, y)
        self.is_bomb = True
        self.type = 7
        self.color = 6

    def place(self, game: 'Tetris') -> None:
        # Bomb block is at index 5 (row 1, col 1 in 4x4 grid)
        bomb_center_x = self.x + 1
        bomb_center_y = self.y + 1
        game.clear_3x3(bomb_center_x, bomb_center_y)
        game.audio.play_bomb()

    def rotate(self) -> None:
        # Bombs do not rotate
        return


# =============================================================================
# AUDIO MANAGER
# =============================================================================
class AudioManager:
    def __init__(self):
        self.line_clear_sound = None
        self.bomb_sound = None

    def play_line_clear(self) -> None:
        if self.line_clear_sound:
            try:
                self.line_clear_sound.play()
            except pygame.error:
                pass

    def play_bomb(self) -> None:
        if self.bomb_sound:
            try:
                self.bomb_sound.play()
            except pygame.error:
                pass

# =============================================================================
# TETRIS GAME CLASS
# =============================================================================
class Tetris:
    def __init__(self, height: int, width: int):
        self.level = 2
        self._score = 0
        self.state = GameState.START
        self.height = height
        self.width = width
        self.x = 100
        self.y = 60
        self.zoom = 20
        self.figure = None
        self.columns_hidden = False
        self.disabled_columns: set = set()
        self.field = self.create_empty_field(height, width)
        self.audio = AudioManager()

    # --- Score encapsulation ---
    @property
    def score(self) -> int:
        return self._score

    @score.setter
    def score(self, value: int) -> None:
        if value >= 0:
            self._score = value
        else:
            logging.warning("Attempted to set a negative score: %d", value)

    def create_empty_field(self, height: int, width: int) -> list:
        return [[0 for _ in range(width)] for _ in range(height)]

    def new_figure(self) -> None:
        bomb_chance = 45 if self.columns_hidden else 20
        if random.randint(1, 100) <= bomb_chance:
            self.figure = BombFigure(3, 0)
        else:
            self.figure = Figure(3, 0)
        self.update_column_visibility()

    def intersects(self) -> bool:
        intersection = False
        for i in range(4):
            for j in range(4):
                if i * 4 + j in self.figure.image():
                    field_x = j + self.figure.x
                    field_y = i + self.figure.y
                    # Disabled column collision
                    if field_x in self.disabled_columns:
                        intersection = True
                    elif (
                        field_y > self.height - 1
                        or field_x > self.width - 1
                        or field_x < 0
                        or (field_y >= 0 and self.field[field_y][field_x] > 0)
                    ):
                        intersection = True
        return intersection

    def break_lines(self) -> None:
        lines = 0
        for i in range(1, self.height):
            zeros = sum(1 for j in range(self.width) if self.field[i][j] == 0)
            if zeros == 0:
                lines += 1
                for i1 in range(i, 1, -1):
                    for j in range(self.width):
                        self.field[i1][j] = self.field[i1 - 1][j]
        if lines > 0:
            self.audio.play_line_clear()
        if lines > 0:
            self.score += lines ** 2
        self.update_column_visibility()

    def go_space(self) -> None:
        while not self.intersects():
            self.figure.y += 1
        self.figure.y -= 1
        self.freeze()

    def go_down(self) -> None:
        self.figure.y += 1
        if self.intersects():
            self.figure.y -= 1
            self.freeze()
        else:
            self.update_column_visibility()

    def go_side(self, dx: int) -> None:
        old_x = self.figure.x
        self.figure.x += dx
        if self.intersects():
            self.figure.x = old_x
        else:
            self.update_column_visibility()

    def rotate(self) -> None:
        old_rotation = self.figure.rotation
        self.figure.rotate()
        if self.intersects():
            self.figure.rotation = old_rotation
        else:
            self.update_column_visibility()

    def fifteenth_row_blocked(self) -> bool:
        return any(self.field[14][col] > 0 for col in range(self.width))

    def update_column_visibility(self) -> None:
        if self.fifteenth_row_blocked():
            self.disabled_columns = {0, self.width - 1}
            self.columns_hidden = True
        else:
            self.disabled_columns = set()
            self.columns_hidden = False

    def freeze(self) -> None:
        self.figure.place(self)
        self.break_lines()
        self.update_column_visibility()
        self.new_figure()
        if self.intersects():
            self.state = GameState.ENTER_NAME

    def clear_3x3(self, center_x: int, center_y: int) -> None:
        for i in range(-1, 2):
            for j in range(-1, 2):
                field_x = center_x + j
                field_y = center_y + i
                if 0 <= field_x < self.width and 0 <= field_y < self.height:
                    self.field[field_y][field_x] = 0
        self.score += 25

    def load_high_scores(self) -> list:
        scoreboard_file = os.path.join(os.path.dirname(__file__), "scoreboard.json")
        if not os.path.exists(scoreboard_file):
            return []
        try:
            with open(scoreboard_file, 'r', encoding='utf-8') as f:
                return json.load(f)
        except (IOError, json.JSONDecodeError) as exc:
            logging.error("High score load failed: %s", exc)
            return []

    def save_high_scores(self, scores: list) -> None:
        scoreboard_file = os.path.join(os.path.dirname(__file__), "scoreboard.json")
        try:
            with open(scoreboard_file, 'w', encoding='utf-8') as f:
                json.dump(scores, f, indent=2)
        except IOError as exc:
            logging.error("Unable to save high scores: %s", exc)

    def add_score(self, player_name: str = "Player") -> list:
        scores = self.load_high_scores()
        scores.append({"name": player_name, "score": self.score})
        scores = sorted(scores, key=lambda x: x["score"], reverse=True)[:10]
        self.save_high_scores(scores)
        return scores

    def reset(self) -> None:
        self.__init__(20, 10)
    def reset(self) -> None:
        self.level = 2
        self._score = 0
        self.state = GameState.START
        self.x = 100
        self.y = 60
        self.zoom = 20
        self.figure = None
        self.columns_hidden = False
        self.disabled_columns = set()
        self.field = self.create_empty_field(self.height, self.width)
# ASSET HELPERS
# =============================================================================
def load_sound(names: list):
    for name in names:
        path = os.path.join(os.path.dirname(__file__), name)
        if os.path.exists(path):
            try:
                return pygame.mixer.Sound(path)
            except pygame.error:
                logging.error("Unable to load sound: %s", path)
    return None


def make_tone_sound(frequency: float, duration: float = 0.15, volume: float = 0.5):
    sample_rate = 44100
    max_amplitude = int(32767 * volume)
    n_samples = int(sample_rate * duration)
    sound_buffer = bytearray()
    for i in range(n_samples):
        sample = int(max_amplitude * math.sin(2 * math.pi * frequency * (i / sample_rate)))
        sound_buffer += sample.to_bytes(2, byteorder='little', signed=True)
    try:
        return pygame.mixer.Sound(buffer=bytes(sound_buffer))
    except pygame.error:
        return None

