# ABSTRACT PIECE BASE CLASS
# =============================================================================
# Abstract base class for all game pieces. It defines common attributes and methods that all pieces must have, like position and abstract methods for image, placing, and rotating.
class AbstractPiece(ABC):
    def __init__(self, x, y):
    # Initializes the Tetris game instance with the given height and width, setting up the game state, field, and audio manager.
        self.x = x
        self.y = y
        self.rotation = 0

    @abstractmethod  # Must return the shape of the piece as a list of indices
    def image(self):
        pass

    @abstractmethod # Must place the piece on the game field
    def place(self, game):
        pass

    @abstractmethod # Must change the rotation of the piece
    def rotate(self):
        pass

# =============================================================================
# FIGURE (Standard Tetromino) 
# =============================================================================
# Class for standard Tetris pieces (tetrominoes). It inherits from AbstractPiece and defines shapes, colors, and behaviors for regular pieces.

class Figure(AbstractPiece):
    figures = [ # List of shapes for each piece type, with different rotations. Each is a list of indices in a 4x4 grid
        [[1, 5, 9, 13], [4, 5, 6, 7]], # I-piece
        [[4, 5, 9, 10], [2, 6, 5, 9]], # O-piece
        [[6, 7, 9, 10], [1, 5, 6, 10]], # S-piece
        [[1, 2, 5, 9], [0, 4, 5, 6], [1, 5, 9, 8], [4, 5, 6, 10]], # L-piece
        [[1, 2, 6, 10], [5, 6, 7, 9], [2, 6, 10, 11], [3, 5, 6, 7]], # J-piece
        [[1, 4, 5, 6], [1, 4, 5, 9], [4, 5, 6, 9], [1, 5, 6, 9]], # T-piece
        [[1, 2, 5, 6]],  # Square piece
        [[5]],  # Bomb: single cube
    ]

    def __init__(self, x, y):
        super().__init__(x, y) 
        self.type = random.randint(0, len(self.figures) - 2)  # Hanap or RNG the pieces but Exclude bomb type
        self.color = random.randint(1, len(colors) - 2) # Randomly choose a color for the piece
        self.is_bomb = False # No Kamikaze

    def image(self): # Return the current shape based on type and rotation
        return self.figures[self.type][self.rotation]

    def place(self, game: 'Tetris') -> None: # Place the piece on the game field by setting the color in the field grid
        for i in range(4): # 4 rows in 4x4 grid
            for j in range(4): # 4 columns
                if i * 4 + j in self.image(): # If this position is part of the piece
                    game.field[i + self.y][j + self.x] = self.color # Set the field color

    def rotate(self) -> None: # Rotate the piece to the next rotation state
        self.rotation = (self.rotation + 1) % len(self.figures[self.type])

