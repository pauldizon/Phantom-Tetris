# Function to load a sound file from a list of names, return None if not found
def load_sound(names: list):
    for name in names:  # Try each name
        path = os.path.join(os.path.dirname(__file__), name)
        if os.path.exists(path):
            try:
                return pygame.mixer.Sound(path)  # Load and return
            except pygame.error:
                logging.error("Unable to load sound: %s", path)
    return None  # None if none work

# Function to generate a simple tone sound using math
def make_tone_sound(frequency: float, duration: float = 0.15, volume: float = 0.5):
    sample_rate = 44100  # Samples per second
    max_amplitude = int(32767 * volume)  # Max volume
    n_samples = int(sample_rate * duration)  # Total samples
    sound_buffer = bytearray()  # Buffer for sound data
    for i in range(n_samples):
        sample = int(max_amplitude * math.sin(2 * math.pi * frequency * (i / sample_rate)))  # Sine wave
        sound_buffer += sample.to_bytes(2, byteorder='little', signed=True)  # Add to buffer
    try:
        return pygame.mixer.Sound(buffer=bytes(sound_buffer))  # Create sound from buffer
    except pygame.error:
        return None

