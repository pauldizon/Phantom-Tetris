# Handle user input events
def handle_events() -> None:
    global done, pressing_down, player_name
    for event in pygame.event.get():  # Get all events
        if event.type == pygame.QUIT:  # Close window
            done = True
        if event.type == pygame.KEYDOWN:  # Key pressed
            if game.state == GameState.START:  # Start screen
                if event.key in (pygame.K_RETURN, pygame.K_SPACE):
                    game.state = GameState.PLAYING  # Start game
                elif event.key == pygame.K_h:
                    game.state = GameState.HOW_TO_PLAY  # Show help
                elif event.key == pygame.K_s:
                    game.state = GameState.SCOREBOARD  # Show scores
            elif game.state == GameState.HOW_TO_PLAY:  # Help screen
                if event.key in (pygame.K_ESCAPE, pygame.K_BACKSPACE):
                    game.state = GameState.START  # Back to start
            elif game.state == GameState.SCOREBOARD:  # Scoreboard
                if event.key in (pygame.K_ESCAPE, pygame.K_BACKSPACE):
                    game.reset()  # Reset and back to start
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound
                    game.state = GameState.START
            elif game.state == GameState.ENTER_NAME:  # Enter name
                if event.key == pygame.K_RETURN and player_name.strip():
                    game.add_score(player_name.strip())  # Save score
                    player_name = ""
                    game.state = GameState.SCOREBOARD  # Show scores
                elif event.key == pygame.K_BACKSPACE:
                    player_name = player_name[:-1]  # Delete char
                elif event.key == pygame.K_ESCAPE:
                    game.add_score("Player")  # Default name
                    player_name = ""
                    game.state = GameState.SCOREBOARD
                elif (
                    len(player_name) < 15  # Max length
                    and event.unicode.isprintable()
                    and event.unicode not in ['\r', '\n', '\t']
                ):
                    player_name += event.unicode  # Add char
            elif game.state == GameState.PLAYING:  # Playing
                if event.key == pygame.K_UP:
                    game.rotate()  # Rotate
                if event.key == pygame.K_DOWN:
                    pressing_down = True  # Start fast drop
                if event.key == pygame.K_LEFT:
                    game.go_side(-1)  # Move left
                if event.key == pygame.K_RIGHT:
                    game.go_side(1)  # Move right
                if event.key == pygame.K_SPACE:
                    game.go_space()  # Hard drop
                if event.key == pygame.K_ESCAPE:
                    game.reset()  # Reset game
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound
            elif game.state == GameState.GAMEOVER:  # Game over
                if event.key == pygame.K_ESCAPE:
                    game.reset()  # Reset
                    game.audio.line_clear_sound = line_clear_sound
                    game.audio.bomb_sound = bomb_sound
                    player_name = ""
        if event.type == pygame.KEYUP:  # Key released
            if event.key == pygame.K_DOWN:
                pressing_down = False  # Stop fast drop

# Update game logic each frame
def update_game() -> None:
    global counter
    if game.state == GameState.PLAYING and game.figure is None:  # If no piece, spawn one
        game.new_figure()
    counter += 1  # Increment counter
    if counter > 100000:  # Prevent overflow
        counter = 0
    fall_speed = 5  # Speed of fall
    if game.state == GameState.PLAYING and (counter % fall_speed == 0 or pressing_down):  # Time to fall
        game.go_down()

