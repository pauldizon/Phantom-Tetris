    if game.figure is not None:
        for i in range(4):
            for j in range(4):
                if i * 4 + j in game.figure.image():
                    col = j + game.figure.x
                    if col not in game.disabled_columns:  # Skip if disabled
                        pygame.draw.rect(screen, colors[game.figure.color], [game.x + game.zoom * col + 1, game.y + game.zoom * (i + game.figure.y) + 1, game.zoom - 2, game.zoom - 2])
    # HUD
    screen.blit(font.render("Score: " + str(game.score), True, WHITE), [0, 0])  # Score
    if game.columns_hidden and game.state == GameState.PLAYING:
        msg = font.render("Outer columns disabled!", True, (255, 0, 0))  # Warning
        screen.blit(msg, msg.get_rect(center=(size[0] // 2, game.y - 12)))
    # GAMEOVER overlay
    if game.state == GameState.GAMEOVER:
        screen.blit(font1.render("Game Over", True, (255, 125, 0)), [20, 150])  # Game over text
        screen.blit(font1.render("Press ESC", True, GOLD), [25, 215])  # Reset
        screen.blit(font.render(f"Your Score: {game.score}", True, GOLD), [60, 290])  # Final score
        screen.blit(font.render("Top Scores:", True, WHITE), [60, 320])  # Top scores
        scores = game.load_high_scores()
        for rank, entry in enumerate(scores[:3], 1):  # Show top 3
            screen.blit(font.render(f"{rank}. {entry['name']}: {entry['score']}", True, WHITE), [70, 320 + rank * 25])
    pygame.display.flip()  # Update display

# =============================================================================
# MAIN LOOP
# =============================================================================
done = False  # Game loop flag
while not done:  # Main loop
    handle_events()  # Handle input
    update_game()  # Update logic
    render_game()  # Draw screen
    clock.tick(fps)  # Limit FPS
pygame.quit()  # Quit Pygame

