# =============================================================================
# Main class for the Tetris game logic. It manages the field, pieces, score, state, and all game actions.





class Tetris:
    # Initialize the game with field dimensions, set default values for level, score, state, positions, etc.
    def __init__(self, height: int, width: int):
        self.level = 2 # Starting level
        self._score = 0 # Private score variable
        self.state = GameState.START # Initial game state is START
        self.height = height # Field height in blocks
        self.width = width # Field width in blocks
        self.x = 100 # X position of the game field on the screen
        self.y = 60 # Y position of the game field on the screen
        self.zoom = 20 # Size of each block
        self.figure = None # Current active piece
        self.columns_hidden = False # Flag to indicate if outer columns are disabled
        self.disabled_columns: set = set() # Set of column indices that are currently disabled
        self.field = self.create_empty_field(height, width) # 2D list for the game field
        self.audio = AudioManager() #DJ

    # --- Score encapsulation ---
    @property  # Property to get the score safely
    def score(self) -> int:
        return self._score

    @score.setter # Setter to set score, ensuring it's not negative
    def score(self, value: int) -> None:
        if value >= 0:
            self._score = value
        else:
            logging.warning("Attempted to set a negative score: %d", value)

    # Create an empty field as a list of lists filled with 0s
    def create_empty_field(self, height: int, width: int) -> list:
        return [[0 for _ in range(width)] for _ in range(height)]

    # Create a new random piece, with higher bomb chance if columns are hidden
    def new_figure(self) -> None:
        bomb_chance = 45 if self.columns_hidden else 20 # Higher chance when hard
        if random.randint(1, 100) <= bomb_chance:
            self.figure = BombFigure(3, 0) # Bomb at position 3,0
        else:
            self.figure = Figure(3, 0) # Regular piece at position 3,0
        self.update_column_visibility()  # Update visibility after spawning

    def intersects(self) -> bool:    # Check if the current piece intersects with boundaries, blocks, or disabled columns
        intersection = False
        for i in range(4): # Check each cell in 4x4 piece grid
            for j in range(4):
                if i * 4 + j in self.figure.image():
                    field_x = j + self.figure.x
                    field_y = i + self.figure.y
                    # Disabled column collision
                    if field_x in self.disabled_columns:
                        intersection = True
                    elif (
                        field_y > self.height - 1
                        or field_x > self.width - 1
                        or field_x < 0
                        or (field_y >= 0 and self.field[field_y][field_x] > 0)
                    ):
                        intersection = True
        return intersection

   # Clear full lines, shift rows down, add score, play sound, update visibility
    def break_lines(self) -> None:
        lines = 0  # Count of lines cleared
        for i in range(1, self.height):  # Start from row 1 (top is 0)
            zeros = sum(1 for j in range(self.width) if self.field[i][j] == 0)  # Count empty cells
            if zeros == 0:  # Full line
                lines += 1
                for i1 in range(i, 1, -1):  # Shift rows down
                    for j in range(self.width):
                        self.field[i1][j] = self.field[i1 - 1][j]
        if lines > 0:
            self.audio.play_line_clear()  # Play sound
        if lines > 0:
            self.score += lines ** 2  # Add score (squared for bonus)
        self.update_column_visibility()  # Update after clearing

    # Drop the piece instantly to the bottom
    def go_space(self) -> None:
        while not self.intersects():  # Move down until it hits
            self.figure.y += 1
        self.figure.y -= 1  # Undo last move
        self.freeze()  # Place it

    # Move piece down one step, freeze if it hits
    def go_down(self) -> None:
        self.figure.y += 1
        if self.intersects():
            self.figure.y -= 1  # Undo
            self.freeze()  # Place
        else:
            self.update_column_visibility()  # Update visibility

    # Move piece left/right by dx, undo if invalid
    def go_side(self, dx: int) -> None:
        old_x = self.figure.x
        self.figure.x += dx
        if self.intersects():
            self.figure.x = old_x  # Undo
        else:
            self.update_column_visibility()

    # Rotate piece, undo if invalid
    def rotate(self) -> None:
        old_rotation = self.figure.rotation
        self.figure.rotate()
        if self.intersects():
            self.figure.rotation = old_rotation  # Undo
        else:
            self.update_column_visibility()

    # Check if row 14 (15th row) has any blocks
    def fifteenth_row_blocked(self) -> bool:
        return any(self.field[14][col] > 0 for col in range(self.width))

    # Hide/show outer columns based on row 14
    def update_column_visibility(self) -> None:
        if self.fifteenth_row_blocked():
            self.disabled_columns = {0, self.width - 1}  # Disable left and right
            self.columns_hidden = True
        else:
            self.disabled_columns = set()  # Enable all
            self.columns_hidden = False

    # Place piece, clear lines, update, spawn new, check game over
    def freeze(self) -> None:
        self.figure.place(self)  # Place on field
        self.break_lines()  # Clear lines
        self.update_column_visibility()  # Update columns
        self.new_figure()  # New piece
        if self.intersects():  # If new piece hits, game over
            self.state = GameState.ENTER_NAME

    # Clear 3x3 area around center for bomb
    def clear_3x3(self, center_x: int, center_y: int) -> None:
        for i in range(-1, 2):  # -1,0,1
            for j in range(-1, 2):
                field_x = center_x + j
                field_y = center_y + i
                if 0 <= field_x < self.width and 0 <= field_y < self.height:  # Within bounds
                    self.field[field_y][field_x] = 0  # Clear
        self.score += 25  # Bonus points

    # Load high scores from JSON file
    def load_high_scores(self) -> list:
        scoreboard_file = os.path.join(os.path.dirname(__file__), "scoreboard.json")
        if not os.path.exists(scoreboard_file):
            return []  # No file, return empty
        try:
            with open(scoreboard_file, 'r', encoding='utf-8') as f:
                return json.load(f)  # Load list
        except (IOError, json.JSONDecodeError) as exc:
            logging.error("High score load failed: %s", exc)
            return []

    # Save high scores to JSON file
    def save_high_scores(self, scores: list) -> None:
        scoreboard_file = os.path.join(os.path.dirname(__file__), "scoreboard.json")
        try:
            with open(scoreboard_file, 'w', encoding='utf-8') as f:
                json.dump(scores, f, indent=2)  # Save with pretty print
        except IOError as exc:
            logging.error("Unable to save high scores: %s", exc)

    # Add current score to list, sort, keep top 10, save
    def add_score(self, player_name: str = "Player") -> list:
        scores = self.load_high_scores()  # Load existing
        scores.append({"name": player_name, "score": self.score})  # Add new
        scores = sorted(scores, key=lambda x: x["score"], reverse=True)[:10]  # Sort and top 10
        self.save_high_scores(scores)  # Save
        return scores


    # Reset game to initial state
    def reset(self) -> None:
        self.level = 2
        self._score = 0
        self.state = GameState.START
        self.x = 100
        self.y = 60
        self.zoom = 20
        self.figure = None
        self.columns_hidden = False
        self.disabled_columns = set()
        self.field = self.create_empty_field(self.height, self.width)

